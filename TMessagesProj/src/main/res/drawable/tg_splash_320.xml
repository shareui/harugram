<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ splash draws the icon inside a circular mask (~2/3 of canvas).
  Size the square Haru launcher so the whole mark stays inside that circle
  (side ≈ diameter / √2).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="112dp"
        android:height="112dp"
        android:gravity="center"
        android:drawable="@mipmap/ic_launcher" />
</layer-list>
